# Copy this file to .env and fill in your values.
# The SIEM dashboard reads this file at startup.

# OpenAI API key – required for the AI Analyzer feature.
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the model used for AI analysis (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
